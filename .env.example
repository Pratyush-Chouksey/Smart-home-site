# Frontend API Origin URL (Should point back to self in production, or localhost:5000 in dev)
VITE_API_URL=http://localhost:5000

# Backend Port Assignment (Typically provided natively by Render/Railway)
PORT=5000

# MongoDB Universal Remote Connection Node (Provide from MongoDB Atlas)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/smartify
